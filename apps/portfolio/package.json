{
  "type": "module",
  "scripts": {
    "build": "node assets.ts && npx @tailwindcss/cli -i web/styles.tw.css -o build/jaspr/styles.css --minify",
    "watch": "npx @tailwindcss/cli -i web/styles.tw.css -o web/styles.css --watch",
    "clean": "rimraf web/styles.css",
    "start": "serve build/jaspr"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3",
    "serve": "^14.2.6",
    "sharp": "^0.35.3",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.0.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0"
  }
}
